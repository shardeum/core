{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "repairInstructions": {
      "type": "array",
      "items": { "$ref": "#/definitions/AccountRepairInstruction" }
    }
  },
  "required": ["repairInstructions"],
  "definitions": {
    "Sign": {
      "type": "object",
      "properties": {
        "owner": { "type": "string" },
        "sig": { "type": "string" }
      },
      "required": ["owner", "sig"]
    },
    "AppliedVote": {
      "type": "object",
      "properties": {
        "txid": { "type": "string" },
        "transaction_result": { "type": "boolean" },
        "account_id": { "type": "array", "items": { "type": "string" } },
        "account_state_hash_after": { "type": "array", "items": { "type": "string" } },
        "account_state_hash_before": { "type": "array", "items": { "type": "string" } },
        "cant_apply": { "type": "boolean" },
        "node_id": { "type": "string" },
        "sign": { "$ref": "#/definitions/Sign" },
        "app_data_hash": { "type": "string" }
      },
      "required": [
        "txid",
        "transaction_result",
        "account_id",
        "account_state_hash_after",
        "account_state_hash_before",
        "cant_apply",
        "node_id"
      ]
    },
    "ConfirmOrChallengeMessage": {
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "nodeId": { "type": "string" },
        "appliedVote": { "$ref": "#/definitions/AppliedVote" },
        "sign": { "$ref": "#/definitions/Sign" }
      },
      "required": ["message", "nodeId", "appliedVote"]
    },
    "Proposal": {
      "type": "object",
      "properties": {
        "applied": { "type": "boolean" },
        "cant_preApply": { "type": "boolean" },
        "accountIDs": { "type": "array", "items": { "type": "string" } },
        "beforeStateHashes": { "type": "array", "items": { "type": "string" } },
        "afterStateHashes": { "type": "array", "items": { "type": "string" } },
        "appReceiptDataHash": { "type": "string" },
        "txid": { "type": "string" }
      },
      "required": [
        "applied",
        "cant_preApply",
        "accountIDs",
        "beforeStateHashes",
        "afterStateHashes",
        "appReceiptDataHash"
      ]
    },
    "SignedReceipt": {
      "type": "object",
      "properties": {
        "proposal": { "$ref": "#/definitions/Proposal" },
        "proposalHash": { "type": "string" },
        "signaturePack": { "type": "array", "items": { "$ref": "#/definitions/Sign" } },
        "voteOffsets": { "type": "array", "items": { "type": "number" } },
        "sign": { "$ref": "#/definitions/Sign" }
      },
      "required": ["proposal", "proposalHash", "signaturePack", "voteOffsets"]
    },
    "WrappedData": {
      "type": "object",
      "properties": {
        "accountId": { "type": "string" },
        "stateId": { "type": "string" },
        "data": {},
        "timestamp": { "type": "number" },
        "syncData": {
          "anyOf": [
            { "type": "object", "additionalProperties": true },
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "array" },
            { "type": "null" }
          ]
        }
      },
      "required": ["accountId", "stateId", "data", "timestamp"]
    },
    "AccountRepairInstruction": {
      "type": "object",
      "properties": {
        "accountID": { "type": "string" },
        "hash": { "type": "string" },
        "txId": { "type": "string" },
        "accountData": { "$ref": "#/definitions/WrappedData" },
        "targetNodeId": { "type": "string" },
        "signedReceipt": { "$ref": "#/definitions/SignedReceipt" }
      },
      "required": [
        "accountID",
        "hash",
        "txId",
        "accountData",
        "targetNodeId",
        "signedReceipt"
      ]
    }
  }
}
